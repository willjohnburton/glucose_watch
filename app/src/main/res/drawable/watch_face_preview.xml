<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#FF000000" />
            <size android:width="320dp" android:height="320dp" />
        </shape>
    </item>
    <item android:gravity="center" android:top="60dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF" />
            <size android:width="180dp" android:height="2dp" />
        </shape>
    </item>
    <item android:gravity="center">
        <shape android:shape="rectangle">
            <solid android:color="#FF4CAF50" />
            <size android:width="120dp" android:height="2dp" />
        </shape>
    </item>
</layer-list>
